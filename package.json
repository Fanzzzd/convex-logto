{
  "name": "convex-logto",
  "version": "0.1.0",
  "description": "Use Logto (self-hosted or cloud) as the auth provider for Convex React apps: an ID-token OIDC bridge plus a signed webhook user-sync, modeled on convex/react-clerk and @convex-dev/workos-authkit.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": "Fanzzzd (https://github.com/Fanzzzd)",
  "keywords": [
    "convex",
    "logto",
    "auth",
    "authentication",
    "oidc",
    "react",
    "webhook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fanzzzd/convex-logto.git"
  },
  "homepage": "https://github.com/Fanzzzd/convex-logto#readme",
  "bugs": "https://github.com/Fanzzzd/convex-logto/issues",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "lint:package": "publint --strict && attw --pack --profile node16",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@logto/react": ">=3.0.0",
    "convex": ">=1.21.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@logto/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@logto/react": "^4.0.14",
    "@types/react": "^19.1.10",
    "convex": "^1.38.0",
    "publint": "^0.3.21",
    "react": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
